<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Personal Blog</h1>

    <% if (articles.length === 0) { %>
        <p>No articles to show</p>
    <% } else { %>
        <ul>
           <% articles.forEach(article => { %>
                <li>
                    <a href="/articles/<%=article.id %>">
                        <%=article.title %>
                    </a>
                </li>
            <% }) %>
        </ul>
    <% } %>
    
</body>
</html>